@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@model List<IconConfigurationDTO>
@{
    var session = HttpContextAccessor.HttpContext.Session;
    var user = session.Get<UserSessionDTO>("UserSession");
    var isLogin = user?.userName != null;
    var lang = loc.localizer["lang"];
    var isAr = lang == "ar";
    var (showAr, showEn) = isAr ? ("display", "none") : ("none", "display");
    var mod = Model.FirstOrDefault(x => x.OrderNo == 1) ?? new();
    var name = isAr ? mod.NameAr : mod.NameEn;
    var desc = isAr ? mod.DescriptionAr : mod.DescriptionEn;
    var imgURL = "img/icons/fnrc.png";//mod.IconConfigurationAttachments.Count > 0 ?
    //mod.IconConfigurationAttachments?.FirstOrDefault().AttachmentTransaction.FilePath : "/img/icons/icon1.svg";
    var url = "https://fnrc.gov.ae/";
    var TotalSecondDelayInStart = int.Parse(Configuration["Session:TotalSecondDelayInStart"]) * 1000;
}
<div class="top-strip">

    <div class="top-left">

        <a class="lang-switch"
           style="display:@showAr"
           asp-controller="Home"
           asp-action="SetLanguage"
           asp-route-culture="en"
           asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")">
            <i class="fa fa-globe"> </i>
            <span class="lang-code" style="vertical-align: top;">EN</span>
        </a>
        <a class="lang-switch"
           style="display:@showEn"
           asp-controller="Home"
           asp-action="SetLanguage"
           asp-route-culture="ar"
           asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")">
            <span class="lang-code" style="padding-bottom: 7px;">ع</span>
            <i class="fa fa-globe"> </i>
        </a>
       @*  @if (isLogin)
        { *@
            <div class="Notification_Icon"  >
                @await Html.PartialAsync("~/views/shared/components/homepage/notificationicon.cshtml", Model)
            </div>
        @* } *@
        <span class="user-info mx-2">
            <i class="fa fa-user"> </i> @loc.localizer["Welcome"], <strong id="username">...</strong>
        </span>


    </div>
    <div class="top-center">
        @* <img src="img/icons/icon8.svg" alt="Menu" /> *@
    </div>
    <div class="top-right">
        <div class=" ">
            <a class="" href="@url" target="_blank" width="80">
                <img src="@imgURL" alt="@name">
            </a>

        </div>
    </div>
</div>

<div id="notifyPopup" class="notify-popup" style="display: none;">
    <div class="notification-content">

        <button class="notify-close" onclick="closeNotify()" style="display: none;">×</button>

        <div class="notify-image-container" style="display: none; margin-bottom: 15px;">
            <div class="me-1 mt-1 mb-3">
                <h3 class="notify-title-img"></h3>
            </div>
            <img class="notify-display-image" src="" style="max-width: 100%; height: auto; border-radius: 8px;" />
        </div>

        <div class="notify-text-container ">
            <div class="d-flex align-items-center position-relative">
                <div class="notif-logo me-5">
                    <img src="/img/icons/fnrc.png" width="80" />
                </div>
                <div class="me-1">
                    <h3 class="notify-title"></h3>
                </div>
                <div></div>
            </div>
            <div>
                <p class="notify-message"></p>
            </div>
        </div>

        <div class="notification-buttons">
            <button class="notify-cancel-btn" onclick="closeNotify()">@loc.localizer["Cancel"]</button>
            <button class="notify-action-btn"></button>
        </div>
    </div>
</div>

<script>

      document.addEventListener("DOMContentLoaded", function () {
           let timer1 = '';     let timer2 = '';
           let revealDelay = @TotalSecondDelayInStart;

           if(!CheckLodingTimeOver()){
               revealDelay = 0;
           }
            
            fetchUserDetail();

            timer1 = setInterval(fetchNotifications, 120000);

            setTimeout(fetchNotificationToDisplay, revealDelay);

            timer2 = setInterval(fetchNotificationToDisplay, 120000);

      });

    function fetchUserDetail()
    {
        fetch("/WhoAmI/me", {
            method: 'GET',
            credentials: 'include'
        })
        .then(response => {
            if (!response.ok) {
                throw new Error("Failed to fetch user");
            }
            return response.json();
        })
        .then(data => {
            document.getElementById("username").textContent = (data.DisplayName);
            fetchNotifications();
        })
        .catch(error => {
            console.error(error);
            document.getElementById("username").textContent = '@Html.Raw(loc.localizer["Guest"])';
        });
    }

     function fetchNotifications() 
     {
        var notificationHTML = "";
        try {
            $.ajax({
                url: "/home/GetNotifications",
                method: "GET",
                success: function (data) {
                    if (!data || !data.message || data.message == '[]') {
                        $('#notificationCount').hide();
                        return;
                    }

                    var countUnRead = data.message.length;
                    if (countUnRead == 0) {
                        $('#notificationCount').hide();
                        notificationHTML += `<div class="text-center mt-5 search-message">
                                                <i class="fa fa-smile-o fa-3x"></i>
                                                <p class="mt-4"> @(loc.localizer["NONotification"]) </p>
                                            </div>`;
                    } else {
                        $('#notificationCount').show().html(countUnRead);
                    }

                    data.message.forEach(x => {
                        var isArabic = '@isAr' == 'True';
                        var displayMessage = isArabic ? x.MessageAr : x.MessageEn;
                        var displayTitle = isArabic ? x.TitleAr : x.TitleEn;

                        // Check for image
                        var imageUrl = (x.NotificationAttachment && x.NotificationAttachment.length > 0)
                            ? x.NotificationAttachment[0].AttachmentTransaction.ThumbPath
                            : null;

                        // Decide what to show in the list item
                        var contentHtml = '';
                        if ((!displayMessage || displayMessage === "null") && imageUrl) {
                            // If no message but image exists, show the image
                            contentHtml = `<img src="${imageUrl}" style="max-height: 40px; max-width: 150px; border-radius: 4px;" alt="Notification Image">`;
                        } else {
                            // Otherwise show text (fallback to title if message is null)
                            var textToShow = (displayMessage && displayMessage !== "null") ? displayMessage : (displayTitle && displayTitle !== "null" ? displayTitle : "");
                            contentHtml = `<span>${textToShow}</span>`;
                        }

                        // Clean the data: Remove newlines and escape single quotes to prevent JS crashes
                        const clean = (str) => {
                            if (!str) return "";
                            return str.replace(/[\r\n]+/g, ' ').replace(/'/g, "\\'");
                        };

                        // Building the call safely, including imageUrl as the last parameter
                        const onclickCall = `NotificationData('${x.Id}',
                            '${clean(x.TitleAr)}',
                            '${clean(x.TitleEn)}',
                            '${clean(x.MessageAr)}',
                            '${clean(x.MessageEn)}',
                            '${clean(x.ActionTextAr)}',
                            '${clean(x.ActionTextEn)}',
                            '${clean(x.ActionUrl)}',
                            '${imageUrl || ""}')`;

                        notificationHTML += `
                            <a rel="noreferrer" class="notification-item p-3" style="cursor:pointer" onclick="${onclickCall}">
                                <div class="d-flex align-items-center">
                                    <i class="fa fa-bell"></i>
                                    <div class="mx-3 flex-grow-1">${contentHtml}</div>
                                </div>
                                <div class="small text-sm-end">
                                    <i class="fa fa-calendar"></i> ${x.CreatedDate ? x.CreatedDate.split("T")[0] : ''}
                                </div>
                            </a>`;
                    });


                    var htmlFinal = `
                        <div id="notifications-container">
                            <div class="title d-flex justify-content-between p-2">
                                <span>@(loc.localizer["Notification"])</span>
                            </div>
                            <div class="notifications-wrapper overflow-y">
                                ${notificationHTML}
                            </div>
                        </div>`;

                    $('#notificationText').html(htmlFinal);
                },
                error: function () {
                    $("#notificationText").html('<div class="p-3 text-danger">Error loading notifications...</div>');
                }
            });
        } catch (e) {
            console.error("Error fetching notifications: ", e);
        }
    }

     function fetchNotificationToDisplay(){
         fetch("/home/GetNotificationsToDisplay", {
                    method: 'GET'
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error("Failed to fetch Notifications To Display");
                    }
                    return response.json();
                })
                .then(x => {
                    console.log(x);
                    $('#Notification_Icon').show();
                    if(x.message == '[]'){
                        return;
                    }
                    var attachment = x.message. NotificationAttachment.length > 0 ?  x.message.NotificationAttachment[0].AttachmentTransaction.FilePath :"";
                     NotificationData(
                        x.message.Id,
                        x.message.TitleAr,
                        x.message.TitleEn,
                        x.message.MessageAr,
                        x.message.MessageEn,
                        x.message.ActionTextAr,
                        x.message.ActionTextEn,
                        x.message.ActionUrl,
                       attachment
                    );
                     playNotificationSound();
                })
                .catch(error => {
                    console.error(error);
                });
    }
          

    function NotificationData(id, titleAr, titleEn, messageAr, messageEn, btnTextAr, btnTextEn, btnURL, imageUrl) {
        var actualTitle = '@isAr' === 'True' ? titleAr : titleEn;
        var actualMessage = '@isAr' === 'True' ? messageAr : messageEn;
        var actualBtnText = '@isAr' === 'True' ? btnTextAr : btnTextEn;

        // Pass imageUrl to the next function
        showNotify(actualTitle, actualMessage, id, actualBtnText, btnURL, imageUrl);
    }

    function showNotify(title, message, id, btnText, btnURL, imageUrl) {
        const popup = document.getElementById("notifyPopup");
        const textContainer = popup.querySelector(".notify-text-container");
        //const notifLogo = popup.querySelector(".notif-logo");
        const imageContainer = popup.querySelector(".notify-image-container");
        const displayImage = popup.querySelector(".notify-display-image");

        if (imageUrl && imageUrl.trim() !== "") {
             popup.querySelector(".notify-title-img").textContent = title;
            imageContainer.style.display = "block";
            displayImage.src = imageUrl;
            textContainer.style.display = "none";
            popup.classList.add("notify-popup-img");
            //notifLogo.style.display = "none";
        } else {
            imageContainer.style.display = "none";
            textContainer.style.display = "block";
            popup.querySelector(".notify-title").textContent = title;
            popup.querySelector(".notify-message").textContent = message;
             popup.classList.remove("notify-popup-img");
        }

        const actionButton = popup.querySelector(".notify-action-btn");
        const closeButton = popup.querySelector(".notify-cancel-btn");
        closeButton.setAttribute('data-id', id);

        if (btnText && btnURL) {
            actionButton.textContent = btnText;
            actionButton.style.display = "inline-block";
            closeButton.style.display = "block"
            actionButton.onclick = function() {
                window.open(btnURL, '_blank', 'noopener');
                closeNotify();
            };
        } else {
            actionButton.textContent = '@Html.Raw(loc.localizer["OK"])';
            actionButton.style.display = "inline-block";
            actionButton.onclick = closeNotify;
            closeButton.style.display = "none"
        }

        popup.style.display = "block";
    }

    function markNotificationAsRead(notificationId) {
        fetch("/home/MarkNotificationAsRead", {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id: notificationId })
        })
        .then(response => {
            if (!response.ok) {
                console.error("Failed to mark notification as read");
            }
        })
        .catch(error => {
            console.error(error);
        });
    }



    function closeNotify() {
        const popup = document.getElementById("notifyPopup");
        const closeButton = popup.querySelector(".notify-cancel-btn");
        const notificationId = closeButton.getAttribute('data-id');
        if (notificationId) {
            markNotificationAsRead(notificationId);
        }
        popup.style.display = "none";
    }


    function playNotificationSound() {
        try {
            const audio = new Audio('/img/beepNotification.mp3');
            audio.volume = @(Configuration["Session:NotificationVolume"] ?? "0.5");
            audio.play().catch(error => {
                // Browser might block audio if no user interaction has occurred yet
                console.warn("Notification sound blocked or failed:", error);
            });
        } catch (error) {
            console.error("Error playing notification sound:", error);
        }
    }



</script>