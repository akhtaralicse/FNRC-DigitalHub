@{
    var lang = loc.localizer["lang"];
    var isAr = lang == "ar";
}
<div class="news-strip">
    <div class="news-label">
        @loc.localizer["News"]
    </div>

    <div class="news-text">
        <div id="newsContainer" class="news-slider">
            <div>  </div>
        </div>
    </div>
</div>


<div class="modal fade" id="newsModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">تفاصيل الخبر</h5>
            </div>
            <div class="modal-body" id="modalBody">
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        fetchLastMonthNews();
    });

    function formatDate(dateStr) {
        if (!dateStr || dateStr === "---" || !dateStr.includes("-")) return dateStr || "---";
        const parts = dateStr.split("-");
        if (parts.length < 3) return dateStr;
        const [year, month, day] = parts;
        return `${day}-${month}-${year}`;
    }

    function fetchLastMonthNews() {
        console.log('===call combined news===');
         
        const apiUrl = `/NewsAPI/GetExternalNews`;

        $.ajax({
            url: apiUrl,
            type: 'GET',
            dataType: 'json',  
            success: function (newsItems) {
                console.log("Combined News received:", newsItems);

                let htmlContent = "";
                const isArabic = '@isAr' == 'True';

                if (!newsItems || newsItems.length === 0) {
                    const noNewsMsg = isArabic ? "لا توجد أخبار حالياً" : "No news available";
                    $('#newsContainer').html(`<span>${noNewsMsg}</span>`);
                    return;
                } 
                for (let i = 0; i < newsItems.length; i++) {
                    const item = newsItems[i];
                     
                    const title = (isArabic ? item.TitleAr : item.TitleEn) || "";
                    const shortDetail = (isArabic ? item.DescriptionAr : item.DescriptionEn) || "";
                    
                    let dateNews = "---";
                    if (item.PublishDate) {
                        // Handle potential space or T separator (ISO)
                        const rawDate = item.PublishDate.split(/[ T]/)[0];
                        dateNews = rawDate.replace(/\//g, '-');
                    }

                    const cleanTitle = title.toString().replace(/"/g, '&quot;');
                    const cleanDetail = shortDetail.toString().replace(/"/g, '&quot;');

                    htmlContent += `
                     <div class="news-item custom-hover-target"
                          data-title="${cleanTitle}"
                          data-desc="${cleanDetail}">
                          📅 ${formatDate(dateNews)}  🔔  ${title}
                     </div>`;
                }

                const $slider = $('#newsContainer');
                 
                if ($slider.hasClass('slick-initialized')) {
                    $slider.slick('unslick');
                }

                $slider.html(htmlContent);
                 
                $slider.slick({
                    slidesToShow: 1,
                    slidesToScroll: 1,
                    autoplay: true,
                    autoplaySpeed: 4000,
                    speed: 800,
                    infinite: true,
                    pauseOnHover: true,
                    arrows: false,
                    dots: false,
                    rtl: $('html').attr('dir') === 'rtl'
                });

                initNewsModalListeners();
            },
            error: function (err) {
                console.error("Error fetching combined news:", err);
                const errorMsg = '@isAr' == 'True' ? "فشل تحميل الأخبار" : "Failed to load news";
                $('#newsContainer').html(`<span>${errorMsg}</span>`);
            }
        });
    }

    function initNewsModalListeners() {
        const newsItems = document.querySelectorAll('.custom-hover-target');
        const modal = document.getElementById('descModal');
        if (!modal) return;
        
        const modalContent = modal.querySelector('.description-modal-content') || modal;

        newsItems.forEach(item => {
            item.addEventListener('mouseenter', function() {
                var title = this.getAttribute('data-title') || "";
                var fullDescription = this.getAttribute('data-desc') || "";
                var limit = 300;
                
                if (fullDescription.length > limit) {
                    fullDescription = fullDescription.substring(0, limit) + "...";
                } 
                modalContent.innerHTML = `<strong>${title}</strong><br/>${fullDescription}`;
                modal.classList.add('active');
            });

            item.addEventListener('mouseleave', function() {
                modal.classList.remove('active');
            });
        });
    }

</script>